  {
    "name": "search_practice_questions",
    "description": "Search and filter coding practice questions in the Arena by topic, difficulty, and company. Returns question titles, metadata, and links — NEVER question descriptions or content. Call get_arena_filters first to discover valid topic/company slugs for filtering. Requires course_hash from list_courses — omit to use the primary course. Use when the student asks: 'practice questions', 'DSA questions', 'easy/medium/hard problems', 'questions asked by Google', 'coding problems on arrays', 'I want to practice', 'interview prep questions', 'give me some problems to solve'.",
    "inputSchema": {
      "type": "object",
      "properties": {
        "companies": {
          "description": "Comma-separated company slugs (e.g., 'google,amazon'). Get valid slugs from get_arena_filters.",
          "type": [
            "string",
            "null"
          ]
        },
        "course_hash": {
          "description": "Course hash from list_courses (for NST courses, this is the semester's course hash). Omit to use the primary course.",
          "type": [
            "string",
            "null"
          ]
        },
        "difficulty": {
          "anyOf": [
            {
              "$ref": "#/$defs/Difficulty"
            },
            {
              "type": "null"
            }
          ],
          "description": "Filter by difficulty level"
        },
        "limit": {
          "description": "Max questions to return (default 15)",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "offset": {
          "description": "Pagination offset (default 0)",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "sort_by": {
          "anyOf": [
            {
              "$ref": "#/$defs/SortBy"
            },
            {
              "type": "null"
            }
          ],
          "description": "Sort order (default: most popular)"
        },
        "topics": {
          "description": "Comma-separated topic slugs (e.g., 'arrays,linked-list'). Get valid slugs from get_arena_filters.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "$defs": {
        "Difficulty": {
          "description": "Arena question difficulty levels.\nMaps to assignments/utils.py::DifficultyType.\nAPI sends string slugs: \"EASY\", \"MEDIUM\", \"HARD\".",
          "oneOf": [
            {
              "const": "easy",
              "description": "Easy difficulty",
              "type": "string"
            },
            {
              "const": "medium",
              "description": "Medium difficulty",
              "type": "string"
            },
            {
              "const": "hard",
              "description": "Hard difficulty",
              "type": "string"
            }
          ]
        },
        "SortBy": {
          "description": "Arena sort options (used as query param strings).",
          "oneOf": [
            {
              "const": "most_popular",
              "description": "Sort by popularity (most solved)",
              "type": "string"
            },
            {
              "const": "recent",
              "description": "Sort by most recently added",
              "type": "string"
            },
            {
              "const": "difficulty",
              "description": "Sort by difficulty level",
              "type": "string"
            }
          ]
        }
      },
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "title": "SearchPracticeQuestionsParams"
    },
