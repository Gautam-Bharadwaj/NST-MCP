{
  "name": "ai-student-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"cross-env BROWSER=none npm run start:vite\" \"npm run start:electron\"",
